{
  "name": "@angeiv/glm",
  "version": "0.5.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "glm": "dist/loader.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angeiv/glm-cli.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "piConfig": {
    "name": "glm",
    "configDir": ".glm"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run build:resources",
    "build:resources": "node scripts/build-resource-extensions.mjs",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "dev": "pnpm run build:resources && tsx src/loader.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prepack": "pnpm run build",
    "sync:agent-resources": "pnpm run build:resources && node scripts/copy-resources.mjs",
    "test": "pnpm run build:resources && vitest --run"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@sinclair/typebox": "^0.34.41",
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "htmlparser2": "^12.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^24.3.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
