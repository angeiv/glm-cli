{
  "name": "@angeiv/glm",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "glm": "dist/loader.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angeiv/glm-cli.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "piConfig": {
    "name": "glm",
    "configDir": ".glm"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-resources.mjs",
    "dev": "tsx src/loader.ts",
    "prepack": "pnpm run build",
    "test": "node scripts/generate-glm-profile-resource.mjs && vitest --run"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.67.6",
    "@mariozechner/pi-coding-agent": "^0.67.6",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@sinclair/typebox": "^0.34.41",
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "htmlparser2": "^12.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
